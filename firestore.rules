rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user has a specific role
    function hasRole(role) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Helper to check if user is staff (Admin or Dispatcher)
    function isStaff() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'dispatcher'];
    }

    // Vehicle Requests Rules
    match /vehicleRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isStaff()
      );
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }
    
    // Publicly readable collections for Driver Job Sheets
    match /trips/{tripId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /trips/{tripId}/stops/{stopId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Core collections - restricted to authenticated users
    match /sites/{siteId} { allow read, write: if isAuthenticated(); }
    match /vehicles/{vehicleId} { allow read, write: if isAuthenticated(); }
    match /companySettings/{id} { allow read, write: if isAuthenticated(); }

    // GPS tracking — อ่านได้เมื่อ login, เขียนเฉพาะฝั่ง server (firebase-admin bypass rules)
    match /vehiclePositions/{deviceId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /vehiclePositionTrails/{id} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Global fallback
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}