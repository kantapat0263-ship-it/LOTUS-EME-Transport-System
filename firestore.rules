rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user has a specific role
    function hasRole(role) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Helper to check if user is staff (Admin or Dispatcher)
    function isStaff() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'dispatcher'];
    }

    // Vehicle Requests Rules
    match /vehicleRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isStaff()
      );
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }
    
    // Publicly readable collections for Driver Job Sheets
    match /trips/{tripId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /trips/{tripId}/stops/{stopId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ประวัติการแก้ไขทริป (หน้า trips/history + ปุ่มเปลี่ยนคนขับใน daily-summary เขียนที่นี่)
    // ต้องมีกฎชัด — เดิมพึ่ง fallback ซึ่งตอนนี้ปิดเป็น deny แล้ว ไม่งั้นการเขียน log พัง
    match /trips/{tripId}/editLogs/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Core collections - restricted to authenticated users
    match /sites/{siteId} { allow read, write: if isAuthenticated(); }
    match /vehicles/{vehicleId} { allow read, write: if isAuthenticated(); }
    match /vehicleTypes/{typeId} { allow read, write: if isAuthenticated(); }
    match /urgentRequests/{requestId} { allow read, write: if isAuthenticated(); }
    match /companySettings/{id} { allow read, write: if isAuthenticated(); }

    // Diesel price history: client อ่านได้อย่างเดียว; เขียนเฉพาะ server cron
    // (firebase-admin ซึ่ง bypass rules อยู่แล้ว) → ไม่มี client ตัวไหนควรเขียนตรงนี้
    match /dieselPriceHistory/{dateId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Global fallback — deny by default.
    // ทุก collection ที่แอปใช้จริงถูกระบุชัดด้านบนหมดแล้ว; collection แปลกปลอม
    // (ไม่ได้ระบุ) จะถูกปฏิเสธ แทนที่จะเปิดให้ user ที่ล็อกอินเข้าถึงได้ทุกอย่าง
    match /{document=**} {
      allow read, write: if false;
    }
  }
}