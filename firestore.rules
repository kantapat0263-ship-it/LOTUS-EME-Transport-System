rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return getUserRole() in ['admin', 'dispatcher'];
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    // Rules for User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Rules for Vehicle Requests
    match /vehicleRequests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.requestedByEmail == request.auth.token.email || 
        isStaff()
      );
      allow update: if request.auth != null && isStaff();
      allow delete: if request.auth != null && isAdmin();
    }

    // Rules for other shared resources (Sites, Vehicles, Drivers, Trips)
    match /sites/{id} { allow read: if request.auth != null; allow write: if request.auth != null && isStaff(); }
    match /vehicles/{id} { allow read: if request.auth != null; allow write: if request.auth != null && isStaff(); }
    match /drivers/{id} { allow read: if request.auth != null; allow write: if request.auth != null && isStaff(); }
    match /trips/{id} { 
      allow read: if request.auth != null; 
      allow write: if request.auth != null && isStaff();
      
      match /editLogs/{logId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && isStaff();
      }
    }

    match /companySettings/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isStaff();
    }

    // Generic fallback for any other paths
    match /{document=**} {
      allow read, write: if request.auth != null && isAdmin();
    }
  }
}