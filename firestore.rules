rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Force deployment trigger with updated explicit rules
    // Updated: 2024-05-07 - Specific collection matches for vehicleRequests and others

    // Allow authenticated users to access vehicleRequests
    match /vehicleRequests/{requestId} {
      allow read, write: if request.auth != null;
    }
    
    // Explicit rules for core collections
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /sites/{siteId} {
      allow read, write: if request.auth != null;
    }
    
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }
    
    match /drivers/{driverId} {
      allow read, write: if request.auth != null;
    }
    
    match /vehicles/{vehicleId} {
      allow read, write: if request.auth != null;
    }
    
    match /companySettings/{id} {
      allow read, write: if request.auth != null;
    }

    // Global fallback for any other collections or subcollections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}