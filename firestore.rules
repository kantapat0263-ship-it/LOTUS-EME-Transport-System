
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // อนุญาตให้เข้าถึงข้อมูลได้ทั้งหมดชั่วคราวเพื่อรองรับระบบ Testing Bypass
      // ในขั้นตอน Production ควรเปลี่ยนกลับเป็น: allow read, write: if request.auth != null;
      allow read, write: if true;
    }
  }
}
