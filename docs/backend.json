{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the application with specific roles and access permissions.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "dispatcher", "viewer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "email", "name", "role", "createdAt", "active"]
    },
    "VehicleRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VehicleRequest",
      "type": "object",
      "description": "A request for a vehicle to be dispatched to one or more locations.",
      "properties": {
        "requestId": { "type": "string" },
        "requestDate": { "type": "string" },
        "requestTime": { "type": "string" },
        "requestedBy": { "type": "string" },
        "requestedByEmail": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "destinations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "siteName": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" },
              "jobDescription": { "type": "string" }
            }
          }
        },
        "note": { "type": "string" },
        "rejectReason": { "type": "string" },
        "tripId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profile data."
    },
    "/vehicleRequests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/VehicleRequest" },
      "description": "Store individual vehicle requests from staff."
    },
    "/sites/{siteId}": {
      "schema": "object",
      "description": "Construction site information."
    },
    "/trips/{tripId}": {
      "schema": "object",
      "description": "Main trip delivery plans."
    },
    "/drivers/{driverId}": {
      "schema": "object",
      "description": "Driver information."
    },
    "/vehicles/{vehicleId}": {
      "schema": "object",
      "description": "Vehicle information."
    },
    "/companySettings/{id}": {
      "schema": "object",
      "description": "System and company settings."
    }
  }
}